    "format:check": "prettier --check \"app/**/*.{ts,tsx,css}\" \"components/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx,md}\" \"docs/**/*.md\" \"README.md\" \"next.config.ts\" \"postcss.config.mjs\" \"eslint.config.mjs\" \"tsconfig.json\" \".github/pull_request_template.md\""
